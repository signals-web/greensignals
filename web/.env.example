# ─── Signal v2 — environment ──────────────────────────────────────────────
# Copy this file to `.env.local` and fill in values. `.env.local` is
# git-ignored. Leaving a variable blank is fine — Signal has sensible
# demo-mode fallbacks for everything except MapTiler.

# Firebase app config, JSON-stringified. When unset, Signal runs in demo
# mode: auth is a stubbed local user, data is stored in localStorage under
# the `sosisu:signal:v1` key. Useful for offline UI work.
#
# Example (all on one line, no real values):
# VITE_FIREBASE_CONFIG='{"apiKey":"AIza...","authDomain":"...firebaseapp.com","projectId":"...","storageBucket":"...appspot.com","messagingSenderId":"...","appId":"1:..."}'
VITE_FIREBASE_CONFIG=

# Point Firebase Auth + Firestore at the local emulators (see code/firebase.json
# for ports — auth 9099, firestore 8080, storage 9199, UI 4000). Only honoured
# when VITE_FIREBASE_CONFIG is also set; the values in that config can be
# placeholders when emulating.
VITE_FIREBASE_EMULATOR=false

# MapTiler API key — required for basemaps + geocoding. Free tier is fine for
# development. Get one at https://www.maptiler.com/. Without this the map
# renders blank and the location search returns no results.
VITE_MAPTILER_KEY=

# ArcGIS Location Platform API key. Get one at https://location.arcgis.com/.
# Optional — leave blank to hide ArcGIS basemaps from the picker. Enables the
# ESRI basemap providers (World Imagery / Streets / Topographic / Gray Canvas).
VITE_ARCGIS_API_KEY=

# Mapbox public token — used by Approach connector mode to fetch walking
# routes via Mapbox Directions. Without this token Approach falls back to
# a straight line from sign to destination. Get a token at
# https://account.mapbox.com/access-tokens/ — the free tier covers far
# more requests than a review session needs.
VITE_MAPBOX_TOKEN=

# Cross-app handoff targets. Override when pointing at a deployed sibling app
# instead of the local dev server. Defaults match the pinned ports in each
# app's vite.config.ts.
VITE_SOLID_URL=http://localhost:5175
VITE_SURFACE_URL=http://localhost:5174
